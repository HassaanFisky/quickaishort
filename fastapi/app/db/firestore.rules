rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user owns the document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      // Users cannot write directly to their profile to prevent credit manipulation.
      // Profile creation and credit updates must be done via the Admin SDK backend.
      allow write: if false; 
    }

    match /video_jobs/{jobId} {
      // Users can only read jobs they own
      allow read: if isOwner(resource.data.uid);
      // Users can create a job if the uid matches their auth token AND they are authenticated
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid);
      // Users cannot update job state (e.g., status, viral_score, output_signed_url).
      // Backend Admin SDK bypasses these rules.
      allow update, delete: if false;
    }

    match /job_events/{jobId}/events/{eventId} {
      // Users can read events for their jobs. Requires careful querying or matching job_id.
      // For simplicity in MVP, we restrict all event reads to backend, 
      // or we trust the parent job ownership.
      allow read: if isAuthenticated(); // Restrict further in production based on parent job
      allow write: if false; // Backend only
    }

    match /agent_sessions/{sessionId} {
      // Internal backend usage only.
      allow read, write: if false; 
    }
  }
}
