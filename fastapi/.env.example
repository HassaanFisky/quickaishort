# =============================================================================
# REQUIRED — app will refuse to start or reject all requests without these
# =============================================================================

# Same value as NEXTAUTH_SECRET in the Next.js frontend. Must match exactly.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Documented historically — NOT implemented in services/auth.py. Do not rely on this.
AUTH_DISABLED=false

# MongoDB Atlas (motor async driver). Get from Atlas → Connect → Drivers.
MONGODB_URI=

# Redis. Upstash free tier works. Format: redis://:<password>@<host>:<port>
# Required for cache, daily limits, token-bucket, and Cloud Tasks deferral state.
REDIS_URL=redis://localhost:6379

# Gemini API key. Enable "Generative Language API" in Google Cloud Console.
GEMINI_API_KEY=

# Signs download URLs. Generate: openssl rand -hex 32
EXPORT_SIGNING_SECRET=

# Full URL of this Cloud Run service — used to build download links.
PUBLIC_API_URL=https://your-backend.a.run.app

# =============================================================================
# REQUIRED for real-time export progress (Pusher Channels)
# Create free app at pusher.com → Channels → Create app
# =============================================================================
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2

# =============================================================================
# OPTIONAL — improves reliability and features, app works without them
# =============================================================================

# Comma-separated extra CORS origins beyond defaults (localhost:3000, quickaishort.online)
ALLOWED_ORIGINS=https://quickaishort.online

# YouTube Data API v3 key — improves /api/info metadata, falls back to yt-dlp
YOUTUBE_API_KEY=

# Netscape cookie file contents for yt-dlp bot-detection bypass.
# Export from logged-in YouTube session with "Get cookies.txt" browser extension.
# Paste entire file as a single string (newlines become \n).
YOUTUBE_COOKIES=

# SerpAPI key — Google Trends grounding in Pre-Flight (100 free/month at serpapi.com)
SERPAPI_KEY=

# YouTube Analytics OAuth JSON — per-channel retention grounding in Pre-Flight
YOUTUBE_OAUTH_CREDENTIALS=

# Pre-Flight tuning
PREFLIGHT_THRESHOLD=65
PREFLIGHT_MAX_ITERATIONS=3


# Gemini model routing (Phase 56 — smart model router)
# Primary / editor commands (pro users)
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
# Budget model — simple commands, background tasks
GEMINI_BUDGET_MODEL=gemini-2.5-flash
# Free tier — always uses the cheapest model
GEMINI_FREE_MODEL=gemini-2.5-flash-lite
# Pro model — escalation-only (complex analysis)
GEMINI_PRO_MODEL=gemini-2.5-pro
# Legacy alias — kept for backward compatibility
GEMINI_MODEL=gemini-2.5-flash

# Redis-shared 429 circuit. Calls are rejected during cooldown instead of
# sleeping inside billed Cloud Run requests or multiplying provider retries.
GEMINI_BACKOFF_BASE_SECONDS=2
GEMINI_BACKOFF_MAX_SECONDS=60
GEMINI_HARD_QUOTA_COOLDOWN_SECONDS=300

# GCP project (Firestore, GCS, and Cloud Tasks)
GOOGLE_CLOUD_PROJECT=quickaishort-agent-494304

# Export URL TTL in seconds (default: 86400 = 24 hours)
EXPORT_URL_TTL_SECONDS=86400

# Cobalt API key — fallback when yt-dlp fails (optional, works without key)
COBALT_API_KEY=

# =============================================================================
# ADK Studio — optional, pipeline degrades gracefully without these
# =============================================================================

# Pexels API key — enables stock video search in ADK Studio Step 2
# Free plan: 200 requests/hour. Create at pexels.com/api/new/
PEXELS_API_KEY=

# Google Cloud TTS API key — enables AI voiceover in ADK Studio
# Enable "Cloud Text-to-Speech API" in Google Cloud Console → APIs & Services.
# Create an API key (not an OAuth credential) restricted to the TTS API.
# =============================================================================
# PRODUCTION GUARDRAILS — critical for cost and stability control
# =============================================================================

# Maximum number of jobs in the render queue before rejecting new requests (default: 50)
MAX_QUEUE_DEPTH=50

# Production uses durable Cloud Tasks to wake a private renderer from zero.
# Keep "rq" only for development or an explicitly operated legacy worker.
RENDER_DISPATCH_MODE=rq
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE=quickai-render
CLOUD_TASKS_RENDER_URL=
CLOUD_TASKS_OIDC_AUDIENCE=
CLOUD_TASKS_INVOKER_SERVICE_ACCOUNT=
CLOUD_TASKS_DISPATCH_DEADLINE_SECONDS=900
CLOUD_TASKS_MAX_ATTEMPTS=3

# Set to "true" to instantly drain/halt new ingestions in case of emergency (default: false)
SAFE_MODE=false

# Max duration of a single export in seconds (hard capped at 180 in code)
MAX_EXPORT_DURATION_S=180

# Cloud Run region for storage signed URLs (default: us-central1)
GCP_REGION=us-central1

# GCS Bucket for media offloading
GCS_BUCKET_NAME=

# =============================================================================
# Studio Project Kernel (EP-002) — server authority for composition snapshots
# Default ON when unset. Set to 0 only to force-disable Kernel routes.
# =============================================================================
STUDIO_PROJECT_KERNEL=1

# Credit gate soft-fail (DEV ONLY). Production must omit or set false.
# When true, AI editor proceeds if stats/credit service is down (burns Gemini).
# CREDITS_SOFT_FAIL=false

# =============================================================================
# STAGING VALIDATION MATRIX (local / staging only — never ship to live prod)
# =============================================================================
# Use this block to validate Next.js integration without live Gemini spend.
# Cloud Run production must set ENVIRONMENT=production (forces MOCK_AI_MODE off).
#
# ENVIRONMENT=staging
# MOCK_AI_MODE=true
# REDIS_URL=redis://:<password>@<host>:<port>
# CLOUD_TASKS_AI_RETRY_URL=https://<private-or-authenticated-retry-endpoint>
# RENDER_DISPATCH_MODE=cloud_tasks
# CLOUD_TASKS_RENDER_URL=https://<quickai-worker-url>
# CLOUD_TASKS_OIDC_AUDIENCE=https://<quickai-worker-url>
# CLOUD_TASKS_INVOKER_SERVICE_ACCOUNT=<sa>@developer.gserviceaccount.com
#
# Leak guards:
# - Do not put MOCK_AI_MODE=true on ENVIRONMENT=production Cloud Run services.
# - Do not expose CLOUD_TASKS_AI_RETRY_URL without OIDC / invoker IAM.
# - Never commit real REDIS_URL / GEMINI_API_KEY / NEXTAUTH_SECRET values.

# =============================================================================
# LOCAL DEVELOPER MOCK SANDBOX (DEV ONLY — never enable in production)
# =============================================================================
# When true, Gemini HTTP is short-circuited. Router + gemini_client return
# structure-compliant timeline / visual fixtures so Next.js can integrate
# without live AI Studio credits. Forced off when ENVIRONMENT=production.
MOCK_AI_MODE=false

# Optional delayed Cloud Tasks target for token-bucket / 429 AI deferrals.
# When unset, deferrals persist in Redis and return RETRY_LATER only.
# Staging example (authenticated endpoint only):
# CLOUD_TASKS_AI_RETRY_URL=https://quickai-api-xxxxx.run.app/tasks/ai-retry
CLOUD_TASKS_AI_RETRY_URL=

# Legacy AI-editor-only mock (also covered by MOCK_AI_MODE above).
# MOCK_AI_EDITOR=false
