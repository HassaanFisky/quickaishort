# --- AI / Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=

# --- External grounding ---
SERPAPI_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_CREDENTIALS=

# --- Pre-Flight tuning ---
PREFLIGHT_THRESHOLD=65
PREFLIGHT_MAX_ITERATIONS=3

# --- Storage ---
MONGODB_URI=

# --- CORS ---
ALLOWED_ORIGINS=

# --- Background queue ---
REDIS_URL=redis://localhost:6379/0

# --- Realtime (optional — Pusher; falls back to native WebSocket if unset) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# --- Export download URL signing ---
EXPORT_SIGNING_SECRET=
EXPORT_URL_TTL_SECONDS=86400

# --- Public URL (used to build signed download links sent to clients) ---
# Set to your Railway backend URL in production, http://localhost:8000 locally
PUBLIC_API_URL=https://your-railway-domain.up.railway.app
