# --- AI / Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=

# --- External grounding & YouTube Bot Bypass ---
SERPAPI_KEY=
# YOUTUBE_API_KEY: YouTube Data API v3 key. Used for /api/info endpoint to fetch
# video metadata via the official API (bypasses yt-dlp bot detection for metadata).
# Create at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
# YOUTUBE_COOKIES: Paste the full text content of a cookies.txt file exported from
# a logged-in YouTube session. Used by yt-dlp as a last-resort authentication layer.
# Export using the 'Get cookies.txt LOCALLY' Chrome extension.
YOUTUBE_COOKIES=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_CREDENTIALS=

# --- Pre-Flight tuning ---
PREFLIGHT_THRESHOLD=65
PREFLIGHT_MAX_ITERATIONS=3

# --- Storage ---
MONGODB_URI=

# --- CORS ---
ALLOWED_ORIGINS=

# --- Background queue ---
REDIS_URL=redis://localhost:6379/0

# --- Realtime (optional — Pusher; falls back to native WebSocket if unset) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# --- Export download URL signing ---
EXPORT_SIGNING_SECRET=
EXPORT_URL_TTL_SECONDS=86400

# --- Public URL (used to build signed download links sent to clients) ---
# Set to your Railway backend URL in production, http://localhost:8000 locally
PUBLIC_API_URL=https://your-railway-domain.up.railway.app
