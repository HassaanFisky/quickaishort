# =============================================================================
# REQUIRED — app will refuse to start or reject all requests without these
# =============================================================================

# Same value as NEXTAUTH_SECRET in the Next.js frontend. Must match exactly.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# false in production. true only for local dev (skips JWT verification).
AUTH_DISABLED=false

# MongoDB Atlas (motor async driver). Get from Atlas → Connect → Drivers.
MONGODB_URI=

# Redis. Upstash free tier works. Format: redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Gemini API key. Enable "Generative Language API" in Google Cloud Console.
GEMINI_API_KEY=

# Signs download URLs. Generate: openssl rand -hex 32
EXPORT_SIGNING_SECRET=

# Full URL of this Cloud Run service — used to build download links.
PUBLIC_API_URL=https://your-backend.a.run.app

# =============================================================================
# REQUIRED for real-time export progress (Pusher Channels)
# Create free app at pusher.com → Channels → Create app
# =============================================================================
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2

# =============================================================================
# OPTIONAL — improves reliability and features, app works without them
# =============================================================================

# Comma-separated extra CORS origins beyond defaults (localhost:3000, quickaishort.online)
ALLOWED_ORIGINS=https://quickaishort.online

# YouTube Data API v3 key — improves /api/info metadata, falls back to yt-dlp
YOUTUBE_API_KEY=

# Netscape cookie file contents for yt-dlp bot-detection bypass.
# Export from logged-in YouTube session with "Get cookies.txt" browser extension.
# Paste entire file as a single string (newlines become \n).
YOUTUBE_COOKIES=

# SerpAPI key — Google Trends grounding in Pre-Flight (100 free/month at serpapi.com)
SERPAPI_KEY=

# YouTube Analytics OAuth JSON — per-channel retention grounding in Pre-Flight
YOUTUBE_OAUTH_CREDENTIALS=

# Pre-Flight tuning
PREFLIGHT_THRESHOLD=65
PREFLIGHT_MAX_ITERATIONS=3


# Gemini model routing (Phase 56 — smart model router)
# Primary / editor commands (pro users)
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
# Budget model — simple commands, background tasks
GEMINI_BUDGET_MODEL=gemini-2.5-flash
# Free tier — always uses the cheapest model
GEMINI_FREE_MODEL=gemini-2.5-flash-lite
# Pro model — escalation-only (complex analysis)
GEMINI_PRO_MODEL=gemini-2.5-pro
# Legacy alias — kept for backward compatibility
GEMINI_MODEL=gemini-2.5-flash

# GCP project (needed if using Firestore for ADK session persistence)
GOOGLE_CLOUD_PROJECT=quickaishort-agent

# Export URL TTL in seconds (default: 86400 = 24 hours)
EXPORT_URL_TTL_SECONDS=86400

# Cobalt API key — fallback when yt-dlp fails (optional, works without key)
COBALT_API_KEY=

# =============================================================================
# ADK Studio — optional, pipeline degrades gracefully without these
# =============================================================================

# Pexels API key — enables stock video search in ADK Studio Step 2
# Free plan: 200 requests/hour. Create at pexels.com/api/new/
PEXELS_API_KEY=

# Google Cloud TTS API key — enables AI voiceover in ADK Studio
# Enable "Cloud Text-to-Speech API" in Google Cloud Console → APIs & Services.
# Create an API key (not an OAuth credential) restricted to the TTS API.
# =============================================================================
# PRODUCTION GUARDRAILS — critical for cost and stability control
# =============================================================================

# Maximum number of jobs in the render queue before rejecting new requests (default: 50)
MAX_QUEUE_DEPTH=50

# Set to "true" to instantly drain/halt new ingestions in case of emergency (default: false)
SAFE_MODE=false

# Max duration of a single export in seconds (hard capped at 180 in code)
MAX_EXPORT_DURATION_S=180

# Cloud Run region for storage signed URLs (default: us-central1)
GCP_REGION=us-central1

# GCS Bucket for media offloading
GCS_BUCKET_NAME=
