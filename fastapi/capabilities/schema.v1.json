{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickaishort.online/schemas/capabilities/schema.v1.json",
  "title": "QuickAI Studio Capability Registry v1",
  "type": "object",
  "required": ["version", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": [
        "id",
        "version",
        "title",
        "description",
        "tags",
        "side_effects",
        "exec_locus",
        "cost_class",
        "latency_class",
        "idempotent",
        "parallel_safe",
        "requires_facets",
        "orchestrator_emit",
        "runtime_status",
        "param_schema"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$",
          "description": "Must equal AiEditorAction.type discriminator"
        },
        "version": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "preview",
              "mutate_project",
              "network",
              "bake",
              "billing",
              "ui_only"
            ]
          },
          "uniqueItems": true
        },
        "exec_locus": {
          "type": "string",
          "enum": ["client", "server", "worker"]
        },
        "cost_class": {
          "type": "string",
          "enum": ["free", "llm", "bake", "network"]
        },
        "latency_class": {
          "type": "string",
          "enum": ["instant", "fast", "slow", "async_job"]
        },
        "idempotent": { "type": "boolean" },
        "parallel_safe": { "type": "boolean" },
        "requires_facets": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "orchestrator_emit": { "type": "boolean" },
        "runtime_status": {
          "type": "string",
          "enum": ["wired", "partial", "schema_only"]
        },
        "compensating_hint": {
          "type": "string",
          "enum": ["undo_event", "none", "inverse_tool"]
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "param_schema": { "type": "object" }
      }
    }
  }
}
