# =============================================================================
# REQUIRED
# =============================================================================

# FastAPI backend URL (no trailing slash)
# Local:      http://localhost:8000
# Production: https://your-backend.a.run.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Must match NEXTAUTH_SECRET in the FastAPI backend exactly.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of this Next.js app
NEXTAUTH_URL=http://localhost:3000

# MongoDB — used by Next.js API routes for user auth (NextAuth sessions + user model)
MONGODB_URI=

# Google OAuth — create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# REQUIRED for real-time export progress
# =============================================================================
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# =============================================================================
# REQUIRED for AI chat panel (/api/ai/chat) — server-side only, never NEXT_PUBLIC_
# =============================================================================
GEMINI_API_KEY=

# =============================================================================
# OPTIONAL — transactional email (welcome / Pro activation) — server-only,
# never NEXT_PUBLIC_. Must match ADMIN_SECRET on the FastAPI backend exactly —
# without it, signup/Pro-activation emails are silently skipped (never block
# the user-facing flow).
# =============================================================================
ADMIN_SECRET=

# =============================================================================
# OPTIONAL — Sentry error monitoring (frontend). Leave unset to disable;
# Sentry.init() is a no-op without a DSN.
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# OPTIONAL — ADK Studio features (backend env vars — no frontend exposure needed)
# These are set in fastapi/.env, not here. Listed for documentation only.
# =============================================================================
# PEXELS_API_KEY        — stock video search in ADK Studio Step 2
# GOOGLE_TTS_API_KEY    — AI voiceover generation in ADK Studio Step 3
# RESEND_API_KEY        — transactional email sending (Phase 46)
